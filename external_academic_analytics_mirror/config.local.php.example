// 4ham Spectrum Analysis — External Mirror receiver
// Local configuration TEMPLATE.
//
// Copy this file to `config.local.php` (gitignored) and fill in real values.
// `config.local.php` is loaded automatically by lib/db.php and lib/auth.php
// when present; this template is only used as a fallback and SHOULD NOT
// contain real secrets.
// ─────────────────────────────────────────────────────

return [
    // MySQL connection (PDO, mysql driver — the only one available on cs5arc.pt).
    'db' => [
        'host'    => '127.0.0.1',
        'port'    => 3306,
        'dbname'  => 'fourham_mirror',
        'user'    => 'fourham_mirror',
        'pass'    => 'CHANGE_ME',
        'charset' => 'utf8mb4',
    ],

    // Map of mirror_name => shared secret (MUST match the plaintext token
    // that was generated by the upstream Admin Config UI / API). The mirror
    // name is sent in the X-4HAM-Mirror-Name header on every push.
    //
    // Example:
    //   'primary' => 'paste-the-plaintext-token-shown-once-here',
    'mirrors' => [
        // 'primary' => 'CHANGE_ME',
    ],

    // Maximum allowed clock skew between sender and receiver, in seconds.
    // Pushes whose X-4HAM-Timestamp falls outside [now-skew, now+skew] are
    // rejected with HTTP 401 (outcome=stale).
    'max_clock_skew_seconds' => 300,

    // Number of seconds a nonce remains "remembered" for replay protection.
    // Should be >= max_clock_skew_seconds.
    'nonce_ttl_seconds' => 900,

    // Optional source allowlist. Each entry can be:
    //   - exact IPv4 / IPv6 address          (e.g. '203.0.113.10', '2001:db8::1')
    //   - CIDR block IPv4 / IPv6              (e.g. '203.0.113.0/24', '2001:db8::/32')
    //   - hostname / FQDN (resolved at request time, supports DDNS)
    //                                          (e.g. '4ham-span.ddns.net')
    // Empty array disables the check. Non-allowlisted requests get 403.
    // Note: hostname resolution adds a DNS lookup per request — keep the list short.
    'allowed_source_ips' => [
        // '203.0.113.10',
        // '4ham-span.ddns.net',
    ],

    // Logging: where to append a one-line summary per ingest attempt.
    // Set to null to disable file logging (DB audit row is always written).
    'access_log' => __DIR__ . '/logs/ingest.log',

    // Number of seconds an ingest request can take before being aborted.
    'request_time_limit' => 30,
];
