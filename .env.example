# Environment variables template for 4ham-spectrum-analysis

# ══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION
# ══════════════════════════════════════════════════════════════════════════════

# Enable authentication (0=disabled, 1=enabled)
AUTH_REQUIRED=0

# Basic authentication credentials
# IMPORTANT: BASIC_AUTH_PASS can be either:
#   - A plaintext password (NOT RECOMMENDED, legacy support only)
#   - A bcrypt hash (RECOMMENDED, more secure)
#
# To generate a bcrypt hash, run:
#   python scripts/hash_password.py
#
# Example hash (password: "changeme"):
#   $2b$12$abcdefghijklmnopqrstuvwxyz1234567890ABCDEFGHIJK
#
# WARNING: Change these defaults in production!
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=changeme

# ══════════════════════════════════════════════════════════════════════════════
# APPLICATION SERVER
# ══════════════════════════════════════════════════════════════════════════════

# Bind host / port used by scripts/server_control.sh and scripts/4ham_launcher.sh
APP_HOST=0.0.0.0
APP_PORT=8000

# ══════════════════════════════════════════════════════════════════════════════
# SECURITY
# ══════════════════════════════════════════════════════════════════════════════

# CORS configuration (0=disabled, 1=enabled)
CORS_ENABLED=1

# Allowed CORS origins (comma-separated, * = allow all)
# Examples:
#   CORS_ORIGINS=*
#   CORS_ORIGINS=http://localhost:3000,http://localhost:8080
#   CORS_ORIGINS=https://yourdomain.com
CORS_ORIGINS=*

# ══════════════════════════════════════════════════════════════════════════════
# DSP CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════

# Automatic Gain Control (AGC)
DSP_AGC_ENABLE=0
DSP_AGC_TARGET_RMS=0.25
DSP_AGC_MAX_GAIN_DB=30.0
DSP_AGC_ALPHA=0.2

# Signal Detection
DSP_SNR_THRESHOLD_DB=6.0
DSP_MIN_BW_HZ=500

# Mode Marker Quality Gate
MARKER_MIN_SNR_DB=10.0
MARKER_MIN_CONFIDENCE=0.55
MARKER_MIN_HITS=2
MARKER_MAX_AGE_S=10.0

# ══════════════════════════════════════════════════════════════════════════════
# WEBSOCKET STREAMING
# ══════════════════════════════════════════════════════════════════════════════

# Spectrum frames per second
WS_SPECTRUM_FPS=5.0

# WebSocket send timeout (seconds)
WS_SEND_TIMEOUT_S=0.1

# Enable spectrum compression (0=disabled, 1=enabled)
WS_COMPRESS_SPECTRUM=1

# ══════════════════════════════════════════════════════════════════════════════
# INTERNAL FT DECODER (Experimental)
# ══════════════════════════════════════════════════════════════════════════════

# Enable internal FT decoder (0=disabled, 1=enabled)
FT_INTERNAL_ENABLE=0

# Modes to decode (comma-separated: FT8,FT4,WSPR)
FT_INTERNAL_MODES=FT8,FT4

# Minimum confidence threshold (0.0 to 1.0)
FT_INTERNAL_MIN_CONFIDENCE=0.0

# Mock events for testing (0=disabled, 1=enabled)
FT_INTERNAL_EMIT_MOCK_EVENTS=0
FT_INTERNAL_MOCK_INTERVAL_S=15.0
FT_INTERNAL_MOCK_CALLSIGN=N0CALL

# ══════════════════════════════════════════════════════════════════════════════
# EXTERNAL FT DECODER (jt9 / wsprd)
# ══════════════════════════════════════════════════════════════════════════════

# Enable external FT decoder (0=disabled, 1=enabled)
FT_EXTERNAL_ENABLE=1

# Modes to decode (comma-separated: FT8,FT4,WSPR)
FT_EXTERNAL_MODES=FT8,FT4

# Command templates
# Available placeholders: {mode_flag}, {period_int}, {wav_path}, {frequency_mhz}
FT_EXTERNAL_COMMAND=jt9 {mode_flag} -p {period_int} -d 3 -a . -t . {wav_path}
FT_EXTERNAL_COMMAND_WSPR=wsprd -d -f {frequency_mhz} {wav_path}

# Target sample rate for audio conversion
FT_EXTERNAL_TARGET_SAMPLE_RATE=12000

# Decode WSPR every N scans
FT_EXTERNAL_WSPR_EVERY_N=5

# ══════════════════════════════════════════════════════════════════════════════
# DIREWOLF KISS TCP DECODER
# ══════════════════════════════════════════════════════════════════════════════

# Enable Direwolf KISS TCP ingest (0=disabled, 1=enabled)
DIREWOLF_KISS_ENABLE=1

# Auto-start Direwolf subprocess (0=disabled, 1=enabled)
DIREWOLF_AUTOSTART=1

# Direwolf launch command
DIREWOLF_CMD=direwolf -t 0 -p

# ══════════════════════════════════════════════════════════════════════════════
# APRS-IS (Internet APRS feed)
# ══════════════════════════════════════════════════════════════════════════════

# Public APRS-IS gateway used to receive packets reported by other stations
# worldwide (complements the local RF pipeline). Defaults work out of the
# box — only change to use a regional server or restrict the area.
#
#   APRS_IS_HOST     — gateway hostname
#                      Global rotation: rotate.aprs2.net (default)
#                      Europe:          euro.aprs2.net
#                      North America:   noam.aprs2.net
#                      South America:   soam.aprs2.net
#                      Asia:            asia.aprs2.net
#   APRS_IS_PORT     — TCP port (14580 = filtered feed, recommended)
#   APRS_IS_RANGE_KM — radius around your QTH for server-side filter.
#                      Larger values = more traffic. 150 km is a sane default.
APRS_IS_HOST=rotate.aprs2.net
APRS_IS_PORT=14580
APRS_IS_RANGE_KM=150

# ══════════════════════════════════════════════════════════════════════════════
# OTHER DECODERS
# ══════════════════════════════════════════════════════════════════════════════

# CW decoder (0=disabled, 1=enabled)
CW_INTERNAL_ENABLE=0

# SSB/Voice decoder (0=disabled, 1=enabled)
SSB_INTERNAL_ENABLE=1

# PSK decoder (0=disabled, 1=enabled)
PSK_INTERNAL_ENABLE=0

# ══════════════════════════════════════════════════════════════════════════════
# EXPORT CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════

# Maximum number of export files to keep
EXPORT_MAX_FILES=50

# Maximum age of exports in days (older files are deleted)
EXPORT_MAX_AGE_DAYS=7

# ══════════════════════════════════════════════════════════════════════════════
# LOGGING
# ══════════════════════════════════════════════════════════════════════════════

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path (empty for stdout only)
LOG_FILE=

# ══════════════════════════════════════════════════════════════════════════════
# ADVANCED
# ══════════════════════════════════════════════════════════════════════════════

# Python optimization level (-1=default, 0=none, 1=remove asserts, 2=remove docstrings)
PYTHONOPTIMIZE=-1

# Disable Python bytecode generation (0=enabled, 1=disabled)
PYTHONDONTWRITEBYTECODE=0

# ══════════════════════════════════════════════════════════════════════════════
# NOTES
# ══════════════════════════════════════════════════════════════════════════════
#
# 1. Copy this file to .env and customize the values
# 2. Never commit .env file to version control (it's in .gitignore)
# 3. Boolean values: 0=false, 1=true, or use true/yes/on
# 4. For production deployment:
#    - Change AUTH_USER and AUTH_PASS
#    - Enable AUTH_REQUIRED=1
#    - Set appropriate LOG_LEVEL
#    - Review decoder settings based on available external tools
#
# 5. For development:
#    - Keep AUTH_REQUIRED=0 for easier testing
#    - Set LOG_LEVEL=DEBUG for verbose output
#    - Enable mock decoders for testing without SDR hardware
#
