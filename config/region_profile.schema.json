{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/4ham/region_profile.schema.json",
  "title": "Region Profile",
  "type": "object",
  "required": ["meta", "bands"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["name", "region", "country", "language_default", "languages_supported"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "region": { "type": "string" },
        "country": { "type": "string", "minLength": 2, "maxLength": 3 },
        "language_default": { "type": "string" },
        "languages_supported": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "bands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "start_hz", "end_hz"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "start_hz": { "type": "integer", "minimum": 0 },
          "end_hz": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "aprs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "frequency_hz": { "type": "integer", "minimum": 0 },
        "modem": { "type": "string" }
      }
    },
    "callsign_validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prefixes_file": { "type": "string" },
        "regex_baseline": { "type": "string" }
      }
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timezone": { "type": "string" },
        "units": { "type": "string" }
      }
    }
  }
}
