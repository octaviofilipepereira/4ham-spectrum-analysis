{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/4ham/scan_config.schema.json",
  "title": "Scan Configuration",
  "type": "object",
  "required": ["scan"],
  "additionalProperties": false,
  "properties": {
    "device": { "type": "string" },
    "decoder_mode": { "type": "string" },
    "region_profile_path": { "type": "string" },
    "cw_step_hz": { "type": "integer", "minimum": 1 },
    "cw_dwell_s": { "type": "number", "exclusiveMinimum": 0 },
    "scan": {
      "type": "object",
      "required": ["band", "start_hz", "end_hz", "step_hz", "dwell_ms", "mode"],
      "additionalProperties": false,
      "properties": {
        "band": { "type": "string" },
        "center_hz": { "type": "integer", "minimum": 0 },
        "start_hz": { "type": "integer", "minimum": 0 },
        "end_hz": { "type": "integer", "minimum": 0 },
        "step_hz": { "type": "integer", "minimum": 1 },
        "dwell_ms": { "type": "integer", "minimum": 1 },
        "settle_ms": { "type": "integer", "minimum": 0 },
        "sample_rate": { "type": "integer", "minimum": 1 },
        "gain": { "type": "number" },
        "mode": { "type": "string", "enum": ["auto", "fixed"] },
        "record_path": { "type": "string" },
        "ssb_focus_enable": { "type": "boolean" },
        "ssb_focus_hold_ms": { "type": "integer", "minimum": 0 },
        "ssb_focus_hits_required": { "type": "integer", "minimum": 1 },
        "ssb_focus_candidate_ttl_s": { "type": "number", "minimum": 1 },
        "ssb_focus_cooldown_s": { "type": "number", "minimum": 0 },
        "ssb_focus_bucket_hz": { "type": "integer", "minimum": 250 },
        "ssb_focus_max_holds_per_pass": { "type": "integer", "minimum": 1, "maximum": 12 }
      }
    }
  }
}
