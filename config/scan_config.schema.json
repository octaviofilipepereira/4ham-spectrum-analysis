{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/4ham/scan_config.schema.json",
  "title": "Scan Configuration",
  "type": "object",
  "required": ["scan"],
  "additionalProperties": false,
  "properties": {
    "device": { "type": "string" },
    "decoder_mode": { "type": "string" },
    "region_profile_path": { "type": "string" },
    "cw_step_hz": { "type": "integer", "minimum": 1 },
    "cw_dwell_s": { "type": "number", "exclusiveMinimum": 0 },
    "rotation": {
      "type": "object",
      "description": "Scan rotation configuration — cycles through band+mode slots automatically.",
      "required": ["slots"],
      "additionalProperties": false,
      "properties": {
        "rotation_mode": {
          "type": "string",
          "enum": ["bands", "modes"],
          "description": "'bands' = each slot has band+mode; 'modes' = single band, multiple modes."
        },
        "band": {
          "type": "string",
          "description": "Band name (only for rotation_mode 'modes')."
        },
        "dwell_s": {
          "type": "integer",
          "minimum": 8,
          "description": "Default dwell time per slot in seconds."
        },
        "loop": {
          "type": "boolean",
          "description": "If true, cycle repeats forever; if false, stop after one pass."
        },
        "modes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Mode list (only for rotation_mode 'modes')."
        },
        "slots": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["band", "mode"],
            "additionalProperties": false,
            "properties": {
              "band": { "type": "string" },
              "mode": { "type": "string" },
              "dwell_s": { "type": "integer", "minimum": 8 }
            }
          },
          "description": "Slot list (for rotation_mode 'bands')."
        }
      }
    },
    "scan": {
      "type": "object",
      "required": ["band", "start_hz", "end_hz", "step_hz", "dwell_ms", "mode"],
      "additionalProperties": false,
      "properties": {
        "band": { "type": "string" },
        "center_hz": { "type": "integer", "minimum": 0 },
        "start_hz": { "type": "integer", "minimum": 0 },
        "end_hz": { "type": "integer", "minimum": 0 },
        "step_hz": { "type": "integer", "minimum": 1 },
        "dwell_ms": { "type": "integer", "minimum": 1 },
        "settle_ms": { "type": "integer", "minimum": 0 },
        "sample_rate": { "type": "integer", "minimum": 1 },
        "gain": { "type": "number" },
        "mode": { "type": "string", "enum": ["auto", "fixed"] },
        "record_path": { "type": "string" },
        "ssb_focus_enable": { "type": "boolean" },
        "ssb_focus_hold_ms": { "type": "integer", "minimum": 0 },
        "ssb_focus_hits_required": { "type": "integer", "minimum": 1 },
        "ssb_focus_candidate_ttl_s": { "type": "number", "minimum": 1 },
        "ssb_focus_cooldown_s": { "type": "number", "minimum": 0 },
        "ssb_focus_bucket_hz": { "type": "integer", "minimum": 250 },
        "ssb_focus_max_holds_per_pass": { "type": "integer", "minimum": 1, "maximum": 12 }
      }
    }
  }
}
