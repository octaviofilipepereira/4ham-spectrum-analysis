#
# ────────────────────────────────────────────────────
#  4ham Spectrum Analysis — External Mirror Receiver
#  .htaccess — Apache web-root protections
# ────────────────────────────────────────────────────
# Block direct web access to library code, configuration and SQL.
<FilesMatch "\.(sql|md|example)$">
    Require all denied
</FilesMatch>
<FilesMatch "^config\.local\.php$">
    Require all denied
</FilesMatch>

# Disable directory listings.
Options -Indexes

# Public dashboard takes precedence over the legacy version.php landing.
DirectoryIndex index.html version.php

# Block direct fetch of PHP includes (lib/db.php etc.) — they only define
# functions, but returning an empty 200 is misleading.  Static assets
# (lib/*.js, lib/*.json) remain accessible.
<FilesMatch "^(db|auth|snapshot)\.php$">
    Require all denied
</FilesMatch>

# ────────────────────────────────────────────────────
#  Cache control — force revalidation of frontend assets so users
#  always pick up the latest deployed version after a `git pull`,
#  while still benefiting from 304 Not Modified responses.
# ────────────────────────────────────────────────────
<IfModule mod_headers.c>
    <FilesMatch "\.(html|js|mjs|css|json|svg)$">
        Header set Cache-Control "no-cache, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Expires "0"
    </FilesMatch>
</IfModule>
